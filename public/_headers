# Cloudflare Pages security headers.
#
# The CSP is the technical enforcement of the product promise ("no data ever
# leaves your device"): connect-src 'self' means the browser itself blocks any
# attempt — ours, a dependency's, or an injected script's — to phone home.
#
# script-src is 'self' only: the anti-FOUC theme script lives in
# /theme-init.js (sync in <head>), so no inline script exists and the browser
# rejects any injected one. style-src keeps 'unsafe-inline' — inline styles
# can't exfiltrate data, so that trade-off is acceptable where the script one
# was not.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
